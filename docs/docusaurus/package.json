{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "@eslint-plugin-codex/docs",
    "version": "0.1.0",
    "private": true,
    "description": "Docusaurus documentation site for eslint-plugin-codex.",
    "keywords": [
        "codex",
        "documentation",
        "docusaurus",
        "eslint",
        "eslint-plugin"
    ],
    "homepage": "https://nick2bad4u.github.io/eslint-plugin-codex/",
    "bugs": {
        "url": "https://github.com/Nick2bad4u/eslint-plugin-codex/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nick2bad4u/eslint-plugin-codex.git"
    },
    "license": "MIT",
    "author": "Nick2bad4u",
    "contributors": [
        {
            "name": "Nick2bad4u",
            "email": "20943337+Nick2bad4u@users.noreply.github.com",
            "url": "https://github.com/Nick2bad4u"
        }
    ],
    "sideEffects": false,
    "main": "docusaurus.config.ts",
    "files": [
        "build"
    ],
    "scripts": {
        "build": "npm run docs:api && docusaurus build",
        "build:fast": "npm run docs:api && cross-env DOCUSAURUS_ENABLE_EXPERIMENTAL=true docusaurus build",
        "build:local": "npm run docs:api && docusaurus build",
        "clear": "docusaurus clear",
        "deploy": "docusaurus deploy",
        "docs:api": "typedoc --options typedoc.config.json",
        "docusaurus": "docusaurus",
        "serve": "docusaurus serve",
        "start": "npm run docs:api && docusaurus start --host localhost",
        "start:devtools": "npm run docs:api && cross-env DOCUSAURUS_BASE_URL=/ docusaurus start --host localhost",
        "type:css": "npx typed-css-modules .\\src",
        "typecheck": "tsc --project tsconfig.json --noEmit",
        "write-heading-ids": "docusaurus write-heading-ids",
        "write-translations": "docusaurus write-translations"
    },
    "dependencies": {
        "@docusaurus/core": "^3.10.1",
        "@docusaurus/faster": "^3.10.1",
        "@docusaurus/plugin-content-docs": "^3.10.1",
        "@docusaurus/plugin-pwa": "^3.10.1",
        "@docusaurus/preset-classic": "^3.10.1",
        "@docusaurus/theme-mermaid": "^3.10.1",
        "@docusaurus/types": "^3.10.1",
        "@easyops-cn/docusaurus-search-local": "^0.55.1",
        "clsx": "^2.1.1",
        "prism-react-renderer": "^2.4.1"
    },
    "devDependencies": {
        "@docusaurus/module-type-aliases": "^3.10.1",
        "@docusaurus/theme-live-codeblock": "^3.10.1",
        "@docusaurus/tsconfig": "^3.10.1",
        "@mdx-js/react": "^3.1.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "docusaurus-plugin-image-zoom": "^3.0.1",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "typed-css-modules": "^0.9.1",
        "typedoc": "^0.28.20",
        "typedoc-config-nick2bad4u": "^2.0.3",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "packageManager": "npm@11.18.0",
    "engines": {
        "node": ">=22.0.0"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": ">=22.0.0",
            "onFail": "error"
        },
        "packageManager": {
            "name": "npm",
            "version": ">=11.0.0",
            "onFail": "error"
        }
    }
}
