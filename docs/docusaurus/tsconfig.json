{
    "$schema": "https://www.schemastore.org/tsconfig.json",
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "isolatedDeclarations": false,
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "skipLibCheck": true,
        "strict": true,
        "types": [
            "node"
        ]
    },
    "exclude": [
        ".docusaurus",
        "build",
        "node_modules"
    ],
    "extends": [
        "../../tsconfig.json",
        "@docusaurus/tsconfig"
    ],
    "include": [
        "docusaurus.config.ts",
        "sidebars.ts",
        "sidebars.developer.ts",
        "sidebars.rules.ts",
        "src/**/*"
    ]
}
